{
	"name": "wikitext-lsp",
	"version": "1.6.3",
	"description": "Standalone language server for MediaWiki Wikitext",
	"keywords": [
		"mediawiki",
		"wikitext",
		"language server",
		"language service",
		"lsp"
	],
	"homepage": "https://github.com/bhsd-harry/vscode-extension-wikiparser/tree/main/server#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/vscode-extension-wikiparser/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"/lib/*.js"
	],
	"bin": {
		"wikitext-lsp": "lib/server.js"
	},
	"main": "./lib/server.js",
	"sideEffects": false,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/vscode-extension-wikiparser.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev"
	},
	"peerDependencies": {
		"mathoid-texvcjs": ">=0.4.0",
		"vscode-css-languageservice": ">=3.0.0",
		"vscode-html-languageservice": ">=3.1.0",
		"vscode-json-languageservice": ">=3.2.0"
	},
	"peerDependenciesMeta": {
		"mathoid-texvcjs": {
			"optional": true
		},
		"vscode-css-languageservice": {
			"optional": true
		},
		"vscode-html-languageservice": {
			"optional": true
		},
		"vscode-json-languageservice": {
			"optional": true
		}
	},
	"dependencies": {
		"vscode-languageserver": "^10.0.0",
		"vscode-languageserver-textdocument": "^1.0.12",
		"wikilint": "^2.44.0"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24.11.0"
	}
}
